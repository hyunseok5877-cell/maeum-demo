{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "마음(Maeum) 디자인 토큰 v0.1 — 모던 미니멀 럭셔리. DECISIONS.md §🎨 참조. 변경 시 CHANGELOG.md 기록.",
  "version": "0.1.0",
  "brand": "maeum",

  "color": {
    "bg": {
      "primary": { "value": "#FAFAF8", "description": "Ivory White — 기본 배경" },
      "surface": { "value": "#FFFFFF", "description": "카드·모달" },
      "obsidian": { "value": "#0F0F0F", "description": "히어로 오버레이·풀블랙 블록" },
      "muted": { "value": "#F2F0EA", "description": "secondary 버튼 호버·태그 배경" }
    },
    "ink": {
      "primary": { "value": "#1A1A1A", "description": "본문 텍스트" },
      "muted": { "value": "#6B6B6B", "description": "보조 텍스트·캡션" },
      "inverse": { "value": "#FAFAF8", "description": "다크 배경 위 텍스트" }
    },
    "line": {
      "default": { "value": "#E6E4DE", "description": "구분선·카드 테두리" },
      "strong": { "value": "#1A1A1A", "description": "focus·active 밑줄" }
    },
    "system": {
      "success": { "value": "#2E7D32" },
      "warning": { "value": "#B26A00" },
      "error": { "value": "#B00020" }
    },
    "accent": {
      "_note": "Phase 1은 액센트 미사용. 3개월 후 재검토. 사용 시 후보:",
      "_candidates": {
        "bordeaux": "#5C0E0E",
        "brass": "#8A7445",
        "marine": "#0E1B3A",
        "forest": "#1F3A2E"
      }
    }
  },

  "font": {
    "family": {
      "display": {
        "primary": "'EB Garamond', 'Noto Serif KR', serif",
        "premium": "'Canela', 'Reckless Neue', 'EB Garamond', serif"
      },
      "body": "'Inter', 'Pretendard', -apple-system, BlinkMacSystemFont, sans-serif",
      "mono": "'JetBrains Mono', ui-monospace, monospace"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600
    },
    "size": {
      "display-xl": { "value": "72px", "lineHeight": 1.05, "letterSpacing": "-0.02em" },
      "display-lg": { "value": "56px", "lineHeight": 1.08, "letterSpacing": "-0.02em" },
      "display-md": { "value": "40px", "lineHeight": 1.12, "letterSpacing": "-0.01em" },
      "title": { "value": "24px", "lineHeight": 1.3, "letterSpacing": "-0.005em" },
      "body-lg": { "value": "18px", "lineHeight": 1.6, "letterSpacing": "0" },
      "body": { "value": "16px", "lineHeight": 1.6, "letterSpacing": "0" },
      "body-sm": { "value": "14px", "lineHeight": 1.5, "letterSpacing": "0" },
      "caption": { "value": "12px", "lineHeight": 1.4, "letterSpacing": "0.04em", "textTransform": "uppercase" }
    }
  },

  "space": {
    "unit": "8px",
    "0": "0",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "8": "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px",
    "20": "80px",
    "24": "96px",
    "30": "120px"
  },

  "section": {
    "padding-y": {
      "desktop": "120px",
      "tablet": "80px",
      "mobile": "64px"
    }
  },

  "grid": {
    "desktop": { "columns": 12, "gutter": "24px", "maxWidth": "1440px" },
    "tablet": { "columns": 8, "gutter": "20px" },
    "mobile": { "columns": 4, "gutter": "16px", "sideMargin": "20px" }
  },

  "radius": {
    "none": "0",
    "sm": "4px",
    "md": "8px",
    "lg": "16px",
    "pill": "999px"
  },

  "shadow": {
    "none": "none",
    "soft": "0 1px 2px rgba(0,0,0,0.04)",
    "card": "0 2px 8px rgba(0,0,0,0.06)",
    "modal": "0 16px 48px rgba(0,0,0,0.12)"
  },

  "duration": {
    "fast": "150ms",
    "base": "200ms",
    "slow": "400ms",
    "hero": "800ms"
  },

  "easing": {
    "default": "cubic-bezier(0.4, 0, 0.2, 1)",
    "out": "cubic-bezier(0, 0, 0.2, 1)",
    "in": "cubic-bezier(0.4, 0, 1, 1)",
    "inout": "cubic-bezier(0.4, 0, 0.2, 1)"
  },

  "breakpoint": {
    "sm": "480px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  },

  "component": {
    "button": {
      "height": "52px",
      "paddingX": "32px",
      "fontSize": "body",
      "fontWeight": 500,
      "radius": "none",
      "transition": "background 180ms cubic-bezier(0,0,0.2,1)",
      "primary": {
        "bg": "{color.ink.primary}",
        "fg": "{color.bg.primary}",
        "hoverBg": "#000000"
      },
      "secondary": {
        "bg": "transparent",
        "fg": "{color.ink.primary}",
        "hoverBg": "{color.bg.muted}",
        "border": "1px solid {color.line.default}"
      },
      "ghost": {
        "bg": "transparent",
        "fg": "{color.ink.primary}",
        "underlineOnHover": true
      },
      "pill": {
        "height": "32px",
        "paddingX": "16px",
        "radius": "pill",
        "bg": "{color.bg.muted}",
        "fg": "{color.ink.primary}"
      }
    },
    "card": {
      "bg": "{color.bg.surface}",
      "padding": "{space.6}",
      "border": "1px solid {color.line.default}",
      "radius": "{radius.none}",
      "imageRatio": "4/5"
    },
    "input": {
      "height": "48px",
      "border": "0 0 1px 0",
      "borderColor": "{color.line.default}",
      "focusBorderColor": "{color.line.strong}",
      "focusBorderWidth": "2px",
      "label": {
        "fontSize": "caption",
        "transform": "uppercase",
        "letterSpacing": "0.04em",
        "marginBottom": "{space.2}"
      }
    },
    "header": {
      "heightExpanded": "72px",
      "heightCompact": "56px",
      "bgScrolled": "rgba(250,250,248,0.92)",
      "backdropBlur": "12px"
    }
  },

  "motion": {
    "respectReducedMotion": true,
    "scrollTriggerOffset": "85%",
    "imageHoverScale": 1.02,
    "pageTransition": "400ms ease-out"
  },

  "a11y": {
    "contrastRatio": 4.5,
    "focusRing": "2px solid {color.line.strong}",
    "focusRingOffset": "2px"
  },

  "image": {
    "webColorTempShift": "+200K",
    "format": ["avif", "webp", "jpg"],
    "quality": 82,
    "heroMinWidth": 2560,
    "cardMinWidth": 1200,
    "aspect": {
      "card": "4/5",
      "hero": "16/9",
      "thumbnail": "1/1",
      "editorial": "9/5"
    }
  },

  "video": {
    "heroLoopSeconds": [8, 15],
    "defaultMuted": true,
    "codec": ["h264", "vp9"],
    "container": ["mp4", "webm"]
  }
}
