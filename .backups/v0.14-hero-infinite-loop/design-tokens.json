{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "마음(Maeum) 디자인 토큰 v0.2 — 모던 미니멀 × 시네마틱 럭셔리. 골드 액센트 해금 + Playfair Display Display. DECISIONS.md §🎨 / docs/07_brand_moodboard.md v0.2 참조.",
  "version": "0.2.0",
  "brand": "maeum",

  "color": {
    "bg": {
      "primary": { "value": "#FAFAF8", "description": "Ivory White — 기본 배경" },
      "ivory": { "value": "#F5F1EA", "description": "Capitolium-style 따뜻한 아이보리 — 장문 섹션·대리석 감성" },
      "surface": { "value": "#FFFFFF", "description": "카드·모달" },
      "obsidian": { "value": "#0F0F0F", "description": "히어로 오버레이·풀블랙 블록" },
      "espresso": { "value": "#2B2420", "description": "다크 섹션 대체 배경 — 풀블랙보다 따뜻" },
      "muted": { "value": "#F2F0EA", "description": "secondary 버튼 호버·태그 배경" }
    },
    "ink": {
      "primary": { "value": "#1A1A1A", "description": "본문 텍스트" },
      "muted": { "value": "#6B6B6B", "description": "보조 텍스트·캡션" },
      "inverse": { "value": "#FAFAF8", "description": "다크 배경 위 텍스트" }
    },
    "line": {
      "default": { "value": "#E6E4DE", "description": "구분선·카드 테두리" },
      "strong": { "value": "#1A1A1A", "description": "focus·active 밑줄" }
    },
    "system": {
      "success": { "value": "#2E7D32" },
      "warning": { "value": "#B26A00" },
      "error": { "value": "#B00020" }
    },
    "accent": {
      "brass": { "value": "#8A7445", "description": "Antique Brass — v0.2부터 해금. 단색만, 그라데이션 금지. 용도: 섹션 챕터 넘버링·텍스트 stroke·대리석 구분선·마퀴 라인" },
      "_note": "v0.2 결정: Brass 1종만 사용. 금색 '그라데이션'은 여전히 금지. 여러 액센트 동시 사용 금지.",
      "_reserved": {
        "bordeaux": "#5C0E0E",
        "marine": "#0E1B3A",
        "forest": "#1F3A2E"
      }
    }
  },

  "font": {
    "family": {
      "display": {
        "primary": "'Playfair Display', 'Cormorant Garamond', 'Noto Serif KR', serif",
        "editorial": "'EB Garamond', 'Noto Serif KR', serif"
      },
      "body": "'Inter', 'Pretendard', -apple-system, BlinkMacSystemFont, sans-serif",
      "mono": "'JetBrains Mono', ui-monospace, monospace"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "black": 900
    },
    "size": {
      "hero": { "value": "clamp(56px, 10vw, 128px)", "lineHeight": 0.96, "letterSpacing": "-0.03em", "description": "챕터 대형 타이틀 (Capitolium hero급)" },
      "display-xl": { "value": "72px", "lineHeight": 1.05, "letterSpacing": "-0.02em" },
      "display-lg": { "value": "56px", "lineHeight": 1.08, "letterSpacing": "-0.02em" },
      "display-md": { "value": "40px", "lineHeight": 1.12, "letterSpacing": "-0.01em" },
      "title": { "value": "24px", "lineHeight": 1.3, "letterSpacing": "-0.005em" },
      "body-lg": { "value": "18px", "lineHeight": 1.6, "letterSpacing": "0" },
      "body": { "value": "16px", "lineHeight": 1.6, "letterSpacing": "0" },
      "body-sm": { "value": "14px", "lineHeight": 1.5, "letterSpacing": "0" },
      "caption": { "value": "12px", "lineHeight": 1.4, "letterSpacing": "0.18em", "textTransform": "uppercase", "description": "v0.2: tracking 0.04 → 0.18 강화 (Capitolium 캡션 톤)" }
    }
  },

  "space": {
    "unit": "8px",
    "0": "0",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "8": "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px",
    "20": "80px",
    "24": "96px",
    "30": "120px",
    "40": "160px"
  },

  "section": {
    "padding-y": {
      "desktop": "160px",
      "tablet": "100px",
      "mobile": "72px",
      "_note": "v0.2: 120/80/64 → 160/100/72 확장. 여백 더 크게 가져가 시네마틱 리듬."
    }
  },

  "grid": {
    "desktop": { "columns": 12, "gutter": "24px", "maxWidth": "1440px" },
    "tablet": { "columns": 8, "gutter": "20px" },
    "mobile": { "columns": 4, "gutter": "16px", "sideMargin": "20px" }
  },

  "radius": {
    "none": "0",
    "sm": "4px",
    "md": "8px",
    "lg": "16px",
    "pill": "999px"
  },

  "shadow": {
    "none": "none",
    "soft": "0 1px 2px rgba(0,0,0,0.04)",
    "card": "0 2px 8px rgba(0,0,0,0.06)",
    "modal": "0 16px 48px rgba(0,0,0,0.12)"
  },

  "duration": {
    "fast": "150ms",
    "base": "200ms",
    "slow": "400ms",
    "cinematic": "1200ms",
    "hero": "800ms"
  },

  "easing": {
    "default": "cubic-bezier(0.4, 0, 0.2, 1)",
    "out": "cubic-bezier(0, 0, 0.2, 1)",
    "in": "cubic-bezier(0.4, 0, 1, 1)",
    "inout": "cubic-bezier(0.4, 0, 0.2, 1)",
    "cinema": "cubic-bezier(0.25, 0.1, 0.25, 1)"
  },

  "breakpoint": {
    "sm": "480px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  },

  "component": {
    "button": {
      "height": "56px",
      "paddingX": "40px",
      "fontSize": "body",
      "fontWeight": 500,
      "radius": "none",
      "transition": "all 280ms cubic-bezier(0.25, 0.1, 0.25, 1)",
      "primary": {
        "bg": "{color.ink.primary}",
        "fg": "{color.bg.primary}",
        "hoverBg": "#000000"
      },
      "secondary": {
        "bg": "transparent",
        "fg": "{color.ink.primary}",
        "hoverBg": "{color.bg.muted}",
        "border": "1px solid {color.line.default}"
      },
      "ghost": {
        "bg": "transparent",
        "fg": "{color.ink.primary}",
        "underlineOnHover": true
      },
      "cinematic": {
        "_note": "Entrer-style — 호버 시 텍스트가 위로 스와이프되며 동일 텍스트가 아래에서 올라옴. 골드 bottom-border.",
        "height": "56px",
        "paddingX": "48px",
        "border": "1px solid {color.accent.brass}",
        "fg": "{color.ink.inverse}",
        "hoverFg": "{color.accent.brass}"
      },
      "pill": {
        "height": "32px",
        "paddingX": "16px",
        "radius": "pill",
        "bg": "{color.bg.muted}",
        "fg": "{color.ink.primary}"
      }
    },
    "card": {
      "bg": "{color.bg.surface}",
      "padding": "{space.6}",
      "border": "1px solid {color.line.default}",
      "radius": "{radius.none}",
      "imageRatio": "4/5"
    },
    "input": {
      "height": "48px",
      "border": "0 0 1px 0",
      "borderColor": "{color.line.default}",
      "focusBorderColor": "{color.line.strong}",
      "focusBorderWidth": "2px",
      "label": {
        "fontSize": "caption",
        "transform": "uppercase",
        "letterSpacing": "0.18em",
        "marginBottom": "{space.2}"
      }
    },
    "header": {
      "heightExpanded": "88px",
      "heightCompact": "64px",
      "bgScrolled": "rgba(250,250,248,0.88)",
      "backdropBlur": "16px"
    },
    "chapter": {
      "_note": "Capitolium-style 챕터 블록",
      "numberFont": "{font.family.display.primary}",
      "numberSize": "14px",
      "numberColor": "{color.accent.brass}",
      "numberTransform": "uppercase",
      "numberLetterSpacing": "0.32em",
      "titleFont": "{font.family.display.primary}",
      "titleSize": "{font.size.hero.value}",
      "trailOffset": "-6px",
      "trailColor": "{color.accent.brass}"
    },
    "marquee": {
      "fontSize": "clamp(32px, 6vw, 88px)",
      "fontFamily": "{font.family.display.primary}",
      "fontStyle": "italic",
      "duration": "40s",
      "borderTop": "1px solid {color.accent.brass}",
      "borderBottom": "1px solid {color.accent.brass}",
      "paddingY": "{space.8}"
    },
    "divider": {
      "marble": {
        "height": "120px",
        "source": "/textures/marble.svg",
        "marginY": "{space.24}"
      },
      "hairline": {
        "height": "1px",
        "bg": "{color.accent.brass}"
      }
    }
  },

  "motion": {
    "respectReducedMotion": true,
    "scrollTriggerOffset": "85%",
    "imageHoverScale": 1.04,
    "imageHoverDuration": "1200ms",
    "pageTransition": "600ms cubic-bezier(0.25, 0.1, 0.25, 1)",
    "fadeIn": {
      "distance": "60px",
      "duration": "1200ms",
      "stagger": "80ms"
    },
    "scrubVideo": {
      "enable": "desktop-only",
      "duration": "2 viewport heights",
      "scrub": 0.5,
      "pin": true
    }
  },

  "a11y": {
    "contrastRatio": 4.5,
    "focusRing": "2px solid {color.accent.brass}",
    "focusRingOffset": "2px"
  },

  "image": {
    "webColorTempShift": "+200K",
    "format": ["avif", "webp", "jpg"],
    "quality": 82,
    "heroMinWidth": 2560,
    "cardMinWidth": 1200,
    "aspect": {
      "card": "4/5",
      "hero": "16/9",
      "thumbnail": "1/1",
      "editorial": "9/5"
    }
  },

  "video": {
    "heroLoopSeconds": [8, 15],
    "defaultMuted": true,
    "codec": ["h264", "vp9"],
    "container": ["mp4", "webm"],
    "scrub": {
      "lengthSeconds": [10, 15],
      "fps": 30,
      "encoding": "H.264 CRF 23",
      "fallback": "/images/scrub-fallback.webp (mobile)"
    }
  }
}
